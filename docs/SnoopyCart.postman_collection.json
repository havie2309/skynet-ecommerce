              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "publishable-key"]
            }
          }
        },
        {
          "name": "Create Payment Intent",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"basketId\": \"{{basketId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/create-payment-intent",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "create-payment-intent"]
            }
          }
        }
      ]
    },
    {
