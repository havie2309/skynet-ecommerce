              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"basketId\": \"{{basketId}}\",\n  \"items\": [\n    {\n      \"productId\": 1,\n      \"productName\": \"Mouse\",\n      \"price\": 50,\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
