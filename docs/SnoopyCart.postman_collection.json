            "url": {
              "raw": "{{baseUrl}}/api/account/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?page=1&pageSize=8&sort=priceAsc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "8" },
                { "key": "sort", "value": "priceAsc" }
              ]
            }
          }
        },
        {
          "name": "Get Product Filters",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/filters",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "filters"]
            }
          }
        },
        {
          "name": "Get Product By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 0,\n  \"name\": \"Keyboard\",\n  \"description\": \"Mechanical keyboard\",\n  \"price\": 120,\n  \"stockQuantity\": 15,\n  \"imageUrl\": \"https://placehold.co/300x300\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": {{productId}},\n  \"name\": \"Updated Keyboard\",\n  \"description\": \"Updated product description\",\n  \"price\": 130,\n  \"stockQuantity\": 12,\n  \"imageUrl\": \"https://placehold.co/300x300\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Delete Product (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Basket",
      "item": [
        {
          "name": "Get Basket",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/basket?id={{basketId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "basket"],
              "query": [
                { "key": "id", "value": "{{basketId}}" }
              ]
            }
          }
        },
        {
          "name": "Update Basket",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{basketId}}\",\n  \"items\": [\n    {\n      \"productId\": 1,\n      \"productName\": \"Mouse\",\n      \"price\": 50,\n      \"quantity\": 1,\n      \"imageUrl\": \"https://placehold.co/120x120\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/basket",
              "host": ["{{baseUrl}}"],
              "path": ["api", "basket"]
            }
          }
        },
        {
          "name": "Delete Basket",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/basket?id={{basketId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "basket"],
              "query": [
                { "key": "id", "value": "{{basketId}}" }
              ]
            }
          }
        }
      ]
    },
