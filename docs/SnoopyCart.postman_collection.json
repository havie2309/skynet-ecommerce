  "item": [
    {
      "name": "Account",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"Test1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/account/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"Test1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/account/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "login"]
